{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/inventory", "destination": "https://yancy-inventory.vercel.app/" },
    { "source": "/inventory/:path*", "destination": "https://yancy-inventory.vercel.app/:path*" },
    { "source": "/deal", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/vcard/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/vcard" }
      ]
    }
  ]
}
